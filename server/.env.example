# 火山引擎 API 配置
# 请复制此文件为 .env 并填入你的 API Key
ARK_API_KEY=your_api_key_here

# LLM Endpoint (Doubao-Seed-2.0-pro)
LLM_EP=your_llm_endpoint_here

# Image Endpoint (Doubao-v1-pro)
IMAGE_EP=your_image_endpoint_here

# Video Endpoint (Doubao-Seedance-1.5-pro)
VIDEO_EP=your_video_endpoint_here

# 服务商路由配置 (ark 或 ali)
LLM_PROVIDER=ark
IMAGE_PROVIDER=ali
VIDEO_PROVIDER=ark

# 阿里灵积 (DashScope) API 配置
DASHSCOPE_API_KEY=your_dashscope_api_key_here
ALI_LLM_MODEL=qwen-plus
ALI_IMAGE_MODEL=qwen-image-2.0-pro
ALI_VIDEO_T2V_MODEL=wan2.7-t2v-2026-04-25
ALI_VIDEO_I2V_MODEL=wan2.7-i2v-2026-04-25

# 服务端口
PORT=3001

